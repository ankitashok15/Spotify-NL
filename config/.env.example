# Environment variables — copy to .env

# ── Phase 1: Scrape (no Google Play API key required) ──
DATABASE_URL=postgresql://spotify:spotify@localhost:5433/spotify_nl
SPOTIFY_APP_ID=com.spotify.music
SCRAPE_DELAY_SECONDS=2
SCRAPE_BATCH_SIZE=200
SCRAPE_MONTHS_BACK=6
# SERPAPI_KEY=                    # Optional fallback only

# ── Phase 2+: Google Gemini (LLM — not OpenAI) ──
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_RAG=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# ── Phase 3+: Vector DB (Qdrant) ──
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# ── Phase 4+: RAG reranking (optional) ──
# COHERE_API_KEY=

# ── Phase 6: Job queue ──
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
# API_KEY=                          # Optional X-API-Key for /agent/query
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# EMBEDDING_PARTITION_BY_YEAR=true
