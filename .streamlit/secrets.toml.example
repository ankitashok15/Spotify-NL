# Copy to Streamlit Cloud → App settings → Secrets (TOML format)
# https://docs.streamlit.io/deploy/streamlit-community-cloud/deploy-your-app/app-settings/secrets-management

# Required for Search, RAG, and Agent pages:
GEMINI_API_KEY = "your-gemini-api-key-from-aistudio.google.com"

DATABASE_URL = "postgresql://user:pass@host:5432/spotify_nl"
GEMINI_MODEL = "gemini-2.5-flash"
GEMINI_MODEL_RAG = "gemini-2.5-flash"
GEMINI_EMBEDDING_MODEL = "gemini-embedding-001"
QDRANT_URL = "https://your-cluster-id.region.aws.cloud.qdrant.io"
QDRANT_API_KEY = "your-qdrant-cloud-api-key"
QDRANT_COLLECTION = "spotify_reviews"
SPOTIFY_APP_ID = "com.spotify.music"
