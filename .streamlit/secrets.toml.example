# Copy to Streamlit Cloud → App settings → Secrets
# https://docs.streamlit.io/deploy/streamlit-community-cloud/deploy-your-app/app-settings/secrets-management

DATABASE_URL = "postgresql://user:pass@host:5432/spotify_nl"
GEMINI_API_KEY = "your-gemini-api-key"
GEMINI_MODEL = "gemini-2.5-flash"
GEMINI_MODEL_RAG = "gemini-2.5-flash"
GEMINI_EMBEDDING_MODEL = "text-embedding-004"
QDRANT_URL = "https://your-qdrant-cloud-url"
QDRANT_COLLECTION = "spotify_reviews"
SPOTIFY_APP_ID = "com.spotify.music"
